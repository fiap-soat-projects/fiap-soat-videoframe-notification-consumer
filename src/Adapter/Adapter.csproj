        </EmbeddedResource>
        <EmbeddedResource Include="Gateways\Notifications\Senders\Templates\SuccessEmailTemplate.html">
            <CopyToOutputDirectory>Always</CopyToOutputDirectory>
        </EmbeddedResource>
    </ItemGroup>

</Project>
